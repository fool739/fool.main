---
import "../styles/global.css"
import ThemeToggle from '../components/ThemeToggle.astro';
import NowPlaying from '../components/NowPlaying.astro';
import Analytics from '@vercel/analytics/astro'
---

<html lang="en">
    <head>
        <title>fool</title>
        <meta name="title" content="FOOL"/>
        <meta name="viewport" content="width=device-width">
        <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
        <meta name="description" content="LIVE ON THE EDGE">

        <!-- Facebook Meta Tags -->
        <meta property="og:url" content="https://fool.ltd">
        <meta property="og:type" content="website">
        <meta property="og:title" content=""FOOL"">
        <meta property="og:description" content="dance on the edge">
        <meta property="og:image" content="/favicon/death.jpg">
        <meta property="og:site_name" content="fool.ltd">

        <!-- Twitter Meta Tags -->
        <meta name="twitter:card" content="summary_large_image">
        <meta property="twitter:domain" content="fool.ltd">
        <meta property="twitter:url" content="https://fool.ltd">
        <meta name="twitter:title" content=""FOOL"">
        <meta name="twitter:description" content="LIVE ON THE EDGE">
        <meta name="twitter:image" content="/favicon/death.jpg">
        
        <!-- Favicon -->
        <link rel="icon" type="image/x-icon" href="/favicon/fav.ico"/>
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
        <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    </head>

    <body style="background-color: var(--bg); color: var(--text);">
        <div class="max-w-3xl mx-auto py-6 px-4 lg:px-6">
            <nav class="fade-in fade-in-1 flex flex-col sm:flex-row sm:justify-between sm:items-center w-full select-none py-4 gap-4">
                <a href="/" class="font-semibold text-3xl text-center sm:text-left" style="color: var(--accent);">fool.ltd</a>
                <div class="hidden md:block">
                    <NowPlaying />
                </div>
                <div class="flex items-center justify-center sm:justify-start gap-6">
                    <a href="/" class="text-xl font-bold hidden sm:block transition-colors" style="color: var(--text);" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'">HOME</a>
                    <a href="/blog" class="text-xl font-bold transition-colors" style="color: var(--text);" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'">BLOG</a>
                    <ThemeToggle />
                </div>
            </nav>

            <div class="fade-in fade-in-2">
                <slot />
            </div>

        </div>
        <Analytics />
    </body>
</html>




